{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksVersion": "1.38.0",
    "installCommand": "pnpm install --no-frozen-lockfile",
    "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/study-app run build && pnpm --filter @workspace/api-server run build",
    "nixPkgs": ["nodejs_22", "pnpm-9_x", "openssl"]
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/db run push && node artifacts/api-server/dist/index.mjs",
    "healthcheckPath": "/api/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
